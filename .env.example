# LiveKit Cloud websocket URL (Vercel may provide LIVEKIT_URL without NEXT_PUBLIC_)
# If you deploy on Vercel, you might receive environment variable names like
# LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET from the LiveKit dashboard.
# For the client-side UI, a public websocket URL should be exposed as NEXT_PUBLIC_LIVEKIT_URL
# (only if you intentionally want it available to browser code). Prefer keeping
# the server-side `LIVEKIT_API_KEY`/`LIVEKIT_API_SECRET` secret and use the token endpoint.

# Example values (DO NOT COMMIT SECRETS)
LIVEKIT_URL=wss://atheena-pmmrg68w.livekit.cloud
LIVEKIT_API_KEY=APIddaF9UyQQ8Lw
LIVEKIT_API_SECRET=ZrodCgw7HkYJk4aAsSFHRvHuvQNcF9wbMy8eHd5zSkH

# Optional public URL used by the client (if you want the client to know it directly)
# NEXT_PUBLIC_LIVEKIT_URL=${LIVEKIT_URL}

# Optional static token for quick UI tests (prefer token endpoint in production)
# NEXT_PUBLIC_LIVEKIT_TOKEN=

# Preferred token endpoint for production deployments (serverless function)
NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=/api/livekit/token

# Room name used by Atheena UI
NEXT_PUBLIC_LIVEKIT_ROOM=atheena-oracle-sanctum
