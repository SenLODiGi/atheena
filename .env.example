# LiveKit Cloud websocket URL
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# Optional static token for quick UI tests (prefer token endpoint in production)
# NEXT_PUBLIC_LIVEKIT_TOKEN=

# Preferred token endpoint for production deployments
NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=/api/livekit/token

# Room name used by Atheena UI
NEXT_PUBLIC_LIVEKIT_ROOM=atheena-oracle-sanctum
